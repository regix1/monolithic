# Monolithic Game Download Cache - Environment Variables
# Copy this file to .env and customize as needed

# === Cache Settings ===
CACHE_DISK_SIZE=1000g
CACHE_INDEX_SIZE=500m
CACHE_MAX_AGE=3560d
CACHE_SLICE_SIZE=1m
MIN_FREE_DISK=10g

# === Network ===
UPSTREAM_DNS=8.8.8.8 8.8.4.4

# === Cache Domains ===
CACHE_DOMAINS_REPO=https://github.com/uklans/cache-domains.git
CACHE_DOMAINS_BRANCH=master
NOFETCH=false

# === Upstream Keepalive ===
# Reuses TCP connections to CDNs for faster cache-miss downloads
ENABLE_UPSTREAM_KEEPALIVE=false
UPSTREAM_KEEPALIVE_CONNECTIONS=16
UPSTREAM_KEEPALIVE_TIMEOUT=4s
UPSTREAM_KEEPALIVE_REQUESTS=10000
UPSTREAM_KEEPALIVE_TIME=60s
# Optional: comma-separated cache identifiers to always exclude from keepalive (e.g. UPSTREAM_KEEPALIVE_EXCLUDE=epic,origin)
# UPSTREAM_KEEPALIVE_EXCLUDE=

# === No-Slice Fallback ===
# Auto-detects servers that don't support Range requests
NOSLICE_FALLBACK=false
NOSLICE_THRESHOLD=3
DECAY_INTERVAL=86400
# Detection strategy: log (scan error.log for slice failures), response (inspect
# upstream Content-Range headers in real time), or both. Default is log.
NOSLICE_DETECT_MODE=log
# How often the background detector scans for new error-log entries. Accepts
# nginx time literals (e.g. 5s, 10s, 1m). Lower = faster reaction, higher = less CPU.
NOSLICE_SCAN_INTERVAL=10s
# Comma-separated list of hostnames to mark as no-slice at startup (skips
# detection). Useful when a problem CDN is already known. e.g. cdn.example.com,assets.bad.cdn
NOSLICE_STATIC_HOSTS=

# === Epic Games ===
# When true, the known Epic Games CDN hosts are proactively routed through
# @noslice so the detector does not have to learn them. Pair with the
# client-side Engine.ini fix in contrib/lancache-epic-fix.ps1.
EPIC_FORCE_NOSLICE=false

# === Boot Reliability ===
# Seconds the entrypoint waits for /data/cache, /data/logs, and /data/config to
# become writable before failing. Increase for slow-to-mount cache disks (ZFS,
# mdadm, NFS, encrypted volumes). See contrib/lancache.service for host-side
# systemd ordering on bare-metal hosts.
VOLUME_WAIT_TIMEOUT=120

# === Nginx ===
NGINX_WORKER_PROCESSES=auto
NGINX_LOG_FORMAT=cachelog
NGINX_LOG_TO_STDOUT=false
# Set to 'off' for btrfs, ZFS, NFS, or CIFS cache volumes
NGINX_SENDFILE=on

# === Timeouts ===
NGINX_PROXY_CONNECT_TIMEOUT=300s
NGINX_PROXY_READ_TIMEOUT=300s
NGINX_PROXY_SEND_TIMEOUT=300s
NGINX_SEND_TIMEOUT=300s

# === Permissions ===
PUID=33
PGID=33
SKIP_PERMS_CHECK=false
FORCE_PERMS_CHECK=false

# === Logging ===
LOGFILE_RETENTION=3560
BEAT_TIME=1h
SUPERVISORD_LOGLEVEL=error
